# Claude Code Observability Stack - ローカルポート設定
#
# 他のサービス(例えば別プロジェクトのローカル開発サーバーが 3000 番を使っている、など)と
# ポートが競合する場合は、ここでホスト側ポートだけ変更してください。
#
# 使い方:
#   cp .env.example .env
#   # 必要なら値を編集
#   docker compose up -d
#
# .env は各自のローカル差分なので git 管理しません(.gitignore 済み)。

GRAFANA_PORT=3001
PROMETHEUS_PORT=9090
LOKI_PORT=3100
TEMPO_PORT=3200
OTLP_GRPC_PORT=4317
OTLP_HTTP_PORT=4318

# OTLP_GRPC_PORT を変えた場合は、settings.json の
# OTEL_EXPORTER_OTLP_ENDPOINT もそのポートに合わせて変更してください。
